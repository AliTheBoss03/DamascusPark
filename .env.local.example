# Copy this file to .env.local and fill in your credentials.
# The app runs on mock data without these – all optional for the MVP demo.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here

# Server-only – never expose to browser. Required for /api/seed and admin ops.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Paymera / SEP (Syrian Electronic Payment Company) ─────────────────────────
# Signing secret from the Paymera merchant dashboard (used for HMAC-SHA256 verification)
PAYMERA_WEBHOOK_SECRET=

# ── Demo accounts (seeded via POST /api/seed) ─────────────────────────────────
# admin@mawqif.sy  |  warden@mawqif.sy  |  driver@mawqif.sy
# Password for all: Demo@Mawqif2025!
